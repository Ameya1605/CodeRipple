{
  "name": "dependency-impact-analyzer",
  "displayName": "Dependency Impact Analyzer",
  "description": "Assess the blast radius of codebase changes.",
  "version": "2.0.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dia.analyzeSymbol",
        "title": "DIA: Analyze Symbol Impact"
      }
    ],
    "configuration": {
      "title": "Dependency Impact Analyzer",
      "properties": {
        "dia.apiUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Backend API URL"
        },
        "dia.repoId": {
          "type": "string",
          "default": "default",
          "description": "Repository ID for indexing"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "typescript": "^5.4.5"
  }
}
