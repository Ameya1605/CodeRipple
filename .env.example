# ── Runtime ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development       # development | staging | production

# ── Redis / Celery ───────────────────────────────────────────────────────────
# Use localhost when running FastAPI natively; redis when inside Docker
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=            # Leave blank to inherit from REDIS_URL
CELERY_RESULT_BACKEND=        # Leave blank to inherit from REDIS_URL

# ── AI Providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-key-here
LLM_PRIMARY=gemini
LLM_SECONDARY=
EMBEDDING_PROVIDER=gemini

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_ENABLED=False
AUTH_DEV_BYPASS_TOKEN=dev-local-token
SECRET_KEY=dev-secret-key-12345

# ── Databases ────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword
QDRANT_URL=http://localhost:6333

# ── Webhooks ─────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=dev-webhook-secret
