#!/bin/sh
# pre-commit hook for Delta Indexing
# Only index staged files

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|ts|tsx|js|jsx|go|rs|java)$')

if [ -n "$STAGED_FILES" ]; then
    echo "⚡ DIA: Indexing staged files..."
    for file in $STAGED_FILES; do
        python scripts/delta_index_cli.py --file "$file"
    done
fi
